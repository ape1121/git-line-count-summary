{
  "name": "git-line-count-summary",
  "displayName": "Git Line Count Summary",
  "description": "Shows added and removed line counts in git changes.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gitLineCountSummary.refresh",
        "title": "Refresh Line Counts",
        "icon": "$(refresh)"
      }
    ],
    "views": {
      "scm": [
        {
          "id": "gitLineCountSummary",
          "name": "Line Changes",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "gitLineCountSummary.refresh",
          "when": "view == gitLineCountSummary",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.44"
  }
}
